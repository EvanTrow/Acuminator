            "acuminatorAngleLevel10": {
              "foreground": "#FD7E14"
            },
            "acuminatorAngleLevel11": {
              "foreground": "#17A2B8"
            },
            "acuminatorAngleLevel12": {
              "foreground": "#E83E8C"
            },
            "acuminatorAngleLevel13": {
              "foreground": "#005CC5"
            },
            "acuminatorAngleLevel14": {
              "foreground": "#218838"
            }
          }
        }
      }
