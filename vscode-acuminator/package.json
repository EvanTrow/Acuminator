{
  "name": "acuminator-vscode",
  "displayName": "Acuminator for VS Code",
  "description": "Acumatica-focused syntax highlighting for C# with Acumatica framework element recognition.",
  "version": "0.1.0",
  "publisher": "acuminator",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "acumatica",
    "acuminator",
    "csharp",
    "bql",
    "px"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "grammars": [
      {
        "scopeName": "source.cs.acumatica",
        "path": "./syntaxes/acumatica-csharp.tmLanguage.json",
        "injectTo": [
          "source.cs"
        ]
      }
    ],
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true,
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "acumaticaDac": {
            "foreground": "#FF9900"
          },
          "acumaticaDacField": {
            "foreground": "#4CFF4F"
          },
          "acumaticaBqlParameter": {
            "foreground": "#FF4FFF"
          },
          "acumaticaBqlOperator": {
            "foreground": "#B579FF"
          },
          "acumaticaConstantPrefix": {
            "foreground": "#FF9999"
          },
          "acumaticaConstantEnding": {
            "foreground": "#019999"
          },
          "acumaticaGraph": {
            "foreground": "#269BC7"
          },
          "acumaticaAction": {
            "foreground": "#BB37A7"
          }
        },
        "[*Light*]": {
          "rules": {
            "acumaticaDac": {
              "foreground": "#FD7E14"
            },
            "acumaticaDacField": {
              "foreground": "#28A745"
            },
            "acumaticaBqlParameter": {
              "foreground": "#F012BE"
            },
            "acumaticaBqlOperator": {
              "foreground": "#6F42C1"
            },
            "acumaticaConstantPrefix": {
              "foreground": "#F1797C"
            },
            "acumaticaConstantEnding": {
              "foreground": "#019999"
            },
            "acumaticaGraph": {
              "foreground": "#269BC7"
            },
            "acumaticaAction": {
              "foreground": "#BB37A7"
            }
          }
        }
      }
    },
    "semanticTokenTypes": [
      {
        "id": "acumaticaDac",
        "description": "DAC type"
      },
      {
        "id": "acumaticaDacField",
        "description": "DAC field type"
      },
      {
        "id": "acumaticaBqlParameter",
        "description": "BQL parameter"
      },
      {
        "id": "acumaticaBqlOperator",
        "description": "BQL operator"
      },
      {
        "id": "acumaticaConstantPrefix",
        "description": "BQL constant prefix"
      },
      {
        "id": "acumaticaConstantEnding",
        "description": "BQL constant ending"
      },
      {
        "id": "acumaticaGraph",
        "description": "PXGraph type"
      },
      {
        "id": "acumaticaAction",
        "description": "PXAction member"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "echo 'no lint configured'",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.5",
    "@vscode/vsce": "^2.26.1"
  },
  "activationEvents": [
    "onLanguage:csharp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Acumatica/Acuminator.git",
    "directory": "vscode-acuminator"
  }
}
