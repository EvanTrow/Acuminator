{
  "name": "acuminator-vscode",
  "displayName": "Acuminator for VS Code",
  "description": "Acumatica-focused syntax highlighting for C# with Acumatica framework element recognition.",
  "version": "0.1.0",
  "publisher": "acuminator",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "acumatica",
    "acuminator",
    "csharp",
    "bql",
    "px"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "grammars": [
      {
        "scopeName": "source.cs.acumatica",
        "path": "./syntaxes/acumatica-csharp.tmLanguage.json",
        "injectTo": [
          "source.cs"
        ]
      }
    ],
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true,
      "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
          "acumaticaDac": {
            "foreground": "#FF9900"
          },
          "acumaticaDacExtension": {
            "foreground": "#CA9966"
          },
          "acumaticaDacField": {
            "foreground": "#4CFF4F"
          },
          "acumaticaBqlParameter": {
            "foreground": "#FF4FFF"
          },
          "acumaticaBqlOperator": {
            "foreground": "#B579FF"
          },
          "acumaticaConstantPrefix": {
            "foreground": "#FF9999"
          },
          "acumaticaConstantEnding": {
            "foreground": "#019999"
          },
          "acumaticaGraph": {
            "foreground": "#269BC7"
          },
          "acumaticaAction": {
            "foreground": "#BB37A7"
          },
          "acuminatorBraceLevel1": {
            "foreground": "#FFFFFF"
          },
          "acuminatorBraceLevel2": {
            "foreground": "#ACA585"
          },
          "acuminatorBraceLevel3": {
            "foreground": "#FFFF4E"
          },
          "acuminatorBraceLevel4": {
            "foreground": "#FF4E4F"
          },
          "acuminatorBraceLevel5": {
            "foreground": "#4EFFFF"
          },
          "acuminatorBraceLevel6": {
            "foreground": "#FF4FFF"
          },
          "acuminatorBraceLevel7": {
            "foreground": "#7ED321"
          },
          "acuminatorBraceLevel8": {
            "foreground": "#CC9965"
          },
          "acuminatorBraceLevel9": {
            "foreground": "#9933FF"
          },
          "acuminatorBraceLevel10": {
            "foreground": "#FF9900"
          },
          "acuminatorBraceLevel11": {
            "foreground": "#019999"
          },
          "acuminatorBraceLevel12": {
            "foreground": "#FFE000"
          },
          "acuminatorBraceLevel13": {
            "foreground": "#2B91AF"
          },
          "acuminatorBraceLevel14": {
            "foreground": "#00FF00"
          },
          "acuminatorAngleLevel1": {
            "foreground": "#FFFFFF"
