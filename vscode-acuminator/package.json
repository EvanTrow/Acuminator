            "acuminatorBraceLevel13": {
              "foreground": "#005CC5"
            },
            "acuminatorBraceLevel14": {
              "foreground": "#218838"
            },
            "acuminatorAngleLevel1": {
              "foreground": "#363A41"
            },
            "acuminatorAngleLevel2": {
              "foreground": "#7C7C7C"
            },
            "acuminatorAngleLevel3": {
              "foreground": "#FFC109"
